# ============================================================
# PROXY — Environment Variables
# Copy this file to .env.local and fill in your values.
# .env.local is gitignored and must never be committed.
# ============================================================

# ── Supabase ─────────────────────────────────────────────────
# Your Supabase project URL. Safe to expose publicly.
PUBLIC_SUPABASE_URL=

# Your Supabase anon key. Safe to expose — RLS protects your data.
PUBLIC_SUPABASE_ANON_KEY=

# Your Supabase service role key.
# SERVER-SIDE ONLY. Bypasses RLS. Never expose to the browser.
# Never prefix with PUBLIC_. Never log this value.
SUPABASE_SERVICE_ROLE_KEY=

# ── AI Model ─────────────────────────────────────────────────
# Groq API key for LLM inference (free tier).
# SERVER-SIDE ONLY. Never expose to the browser.
# Get yours at: https://console.groq.com
GROQ_API_KEY=

# ── MCP Server ───────────────────────────────────────────────
# Shared secret for authenticating requests to your MCP server.
# SERVER-SIDE ONLY. Generate with: openssl rand -hex 32
MCP_SECRET=

# The URL of your deployed Cloudflare Worker MCP server.
# Example: https://proxy-mcp.your-username.workers.dev
MCP_SERVER_URL=

# ── Portfolio Sync ────────────────────────────────────────────
# GitHub webhook secret for verifying portfolio update webhooks.
# SERVER-SIDE ONLY. Generate with: openssl rand -hex 32
GITHUB_WEBHOOK_SECRET=

# ── App ──────────────────────────────────────────────────────
# The public URL of your deployed app.
# Used for redirects and webhook configuration.
# Example: https://proxy.vercel.app
PUBLIC_APP_URL=
